# ============================================
# KisanCall AI - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# Twilio Credentials (from https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Your personal phone number (system will call this for testing)
MY_PHONE_NUMBER=+91XXXXXXXXXX

# Groq API Configuration (from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Server Configuration
HOST=0.0.0.0
PORT=8000
